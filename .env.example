# --- Email (Resend) ---
# Creá una cuenta gratuita en https://resend.com y generá un API key.
# Free tier: 3000 emails/mes, 100/día.
RESEND_API_KEY=

# Dirección desde la que salen los emails (debe ser un dominio verificado en Resend).
# Para desarrollo podés usar: onboarding@resend.dev
EMAIL_FROM=Vertix <notificaciones@vertix.com.ar>

# Dirección interna que recibe las notificaciones de cada formulario.
EMAIL_TO=info@vertix.com.ar

# --- Google Sheets (tasas) ---
# La hoja "tasas" debe tener una fila por servicio con la TNA ANUAL en %:
#   cheques_directo | 48     (tasa de descuento, variable)
#   cheques_comitente | 35
#   arancel_cheques | 2,5    (arancel de la empresa; se suma a la tasa)
#   prestamos_ph | 72
#   prestamos_pj | 82
# (También se acepta una fila "cheques" como alias para ambas modalidades.)
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_CRM_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- HubSpot (CRM) ---
# Vacío por ahora — se activa cuando creen la cuenta.
HUBSPOT_API_KEY=

# --- BCRA (Central de Deudores) ---
# Verificación de situación crediticia del librador (API pública, sin key).
# Poné "false" para desactivar el chequeo/bloqueo. Por defecto está activo.
BCRA_CHECK_ENABLED=true
